# Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
env/

# Editor / OS
.vscode/
.idea/
.DS_Store

# Local env / secrets -- NEVER commit a real .env, only .env.example.
# The leading ** matches at any depth, so app/.env, app/.backups/.env,
# etc. are all covered.  Match-anywhere.  Do NOT remove or this file
# bleeds API keys into the repo (it already happened once -- rotate
# every key listed in the leaked .env before relying on this rule).
.env
**/.env
.env.local
**/.env.local

# Runtime artifacts
*.log

# Backup snapshots — these are timestamped copies created by ad-hoc
# audit/restructure scripts and should never be tracked.  History lives
# in git; do not commit a second copy of the tree.
**/.backups/

# Props backtest output — per-run snapshots and the rolling baseline are
# developer/Railway artifacts, not source.  Keep them out of the repo;
# Supabase is the cross-environment persistence layer for cross-PR diffs.
**/.cache/backtest_results_*.json
**/.cache/backtest_baseline.json

# Props regression metadata — pitcher_feature_names + batter_feature_names
# are written wholesale by every training run.  When parallel branches
# train opposite sides (one --skip-pitcher, the other --skip-batter), they
# can't auto-merge cleanly even with _save_reg_metadata's read-modify-write
# logic, because the timestamp + the side-this-branch-actually-trained both
# diff.  The hardcoded _PITCHER_FEATURE_NAMES / _BATTER_FEATURE_NAMES
# constants in props_model.py are the source of truth at inference; the
# file is restored from Supabase on cold boot when present.  Stop tracking
# it in git so PR-merge conflicts on this one file never happen again.
**/.cache/props_reg_metadata.json

# Player-similarity clusters — regenerated nightly by the 3 AM prefetch job
# (recompute_clusters) and mirrored to Supabase as similarity_{market}_{date}.
# It's a derived artifact, not source, so keep it out of the repo.
**/.cache/player_similarity_clusters.json

# Bet ledgers — bankroll + bets are now stored ONLY in Supabase (the
# rebuilt model_/personal_ ledger tables).  These local JSON files were
# git-tracked, so Railway re-cloned the committed copy on every redeploy
# and the model bankroll kept reverting to the stale $739.  Keep them out
# of the repo so a committed balance can never repopulate again.
**/data/ledger.json
**/data/wnba_ledger.json
