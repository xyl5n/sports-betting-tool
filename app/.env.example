# ============================================================
# Sports Betting AI -- Environment Variables
# ------------------------------------------------------------
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your real keys in the .env copy.
# 3. NEVER commit the .env file.  The repo's .gitignore excludes
#    .env at any depth, but double-check `git status` before you
#    push -- a leaked key here = a leaked key in git history
#    forever (the only true cleanup is to rotate the key).
# 4. On Railway / Render / etc., set these as platform env vars,
#    not as a .env file in the container image.
# ============================================================

# ------------------------------------------------------------
# Primary data / odds sources
# ------------------------------------------------------------

# The Odds API -- PRIMARY odds source (moneyline, spread, totals for MLB + WNBA)
# Sign up at https://the-odds-api.com (free tier: 500 req/month).
# Daily Supabase cache reduces upstream usage to ~1 call per sport per day.
ODDS_API_KEY=your_odds_api_key_here

# SharpAPI -- fallback odds source (only used if The Odds API call raises)
# Sign up at https://sharpapi.io (free tier available; Hobby $79/mo for production)
SHARPAPI_KEY=your_sharpapi_key_here

# API-Sports -- game results for MLB (primary source)
# Sign up at https://api-sports.io (free tier: 100 req/day)
# Free plan covers seasons 2022-2025 only.
API_SPORTS_KEY=your_api_sports_key_here

# Anthropic -- Claude AI assistant (optional, for in-app AI features)
# Sign up at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# ------------------------------------------------------------
# App configuration
# ------------------------------------------------------------

SEASON=2025
BANKROLL=1000

# ------------------------------------------------------------
# Supabase -- persistent data store for bets / bankroll / records
# Optional.  When SUPABASE_URL and SUPABASE_KEY are set, the app
# dual-writes every ledger change to both Supabase AND the local
# JSON files.  When either is missing or Supabase is unreachable
# the app falls back to JSON-only mode automatically and never
# crashes.  See app/db/schema.sql for the table definitions you
# need to run once in the Supabase SQL editor.
# ------------------------------------------------------------

SUPABASE_URL=your_supabase_project_url_here
SUPABASE_KEY=your_supabase_anon_or_service_key_here

# ------------------------------------------------------------
# Fallback data sources
# MLB fallback order:  API-Sports -> ESPN (free) -> BallDontLie SDK
# WNBA fallback order: stats.wnba.com (free) -> ESPN (free)
#                      -> BallDontLie SDK -> sportsdataverse (pip package)
# sportsdataverse is the Python equivalent of the R wehoop package.
# ------------------------------------------------------------

# BallDontLie -- MLB + WNBA game results (MLB fallback 2, WNBA fallback 3)
# Official Python SDK: pip install balldontlie
# Sign up free at https://www.balldontlie.io
# Free tier: MLB game scores. WNBA requires paid plan ($9.99/mo Elite).
BALLDONTLIE_API_KEY=your_balldontlie_key_here

# SportsDataIO -- supplemental team stats, standings, rosters, player stats
# Covers MLB and WNBA. Free trial at https://sportsdata.io/cart/free-trial
# Data validation (50% threshold) is applied automatically to guard against
# scrambled values that the free trial may return.
SPORTSDATAIO_API_KEY=your_sportsdataio_key_here
